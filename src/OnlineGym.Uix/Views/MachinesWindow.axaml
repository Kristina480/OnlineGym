<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="OnlineGym.Uix.Views.MachinesWindow"
        Width="750"
        Height="520"
        MinWidth="650"
        MinHeight="450"
        Title="Upravljanje spravama"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="25"
          RowDefinitions="Auto,*,Auto"
          ColumnDefinitions="2*,20,3*">

        <!-- Naslov -->
        <TextBlock Grid.Row="0"
                   Grid.ColumnSpan="3"
                   Text="Sprave za vežbanje"
                   FontSize="26"
                   FontWeight="Bold"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,20"/>

        <!-- Leva strana -->
        <Border Grid.Row="1"
                Grid.Column="0"
                BorderBrush="Gray"
                BorderThickness="1"
                CornerRadius="5"
                Padding="10">

            <Grid RowDefinitions="Auto,*">

                <TextBlock Grid.Row="0"
                           Text="Postojeće sprave"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Margin="0,0,0,10"/>

                <ListBox x:Name="MachinesListBox"
                         Grid.Row="1"
                         SelectionChanged="OnMachineSelectionChanged"/>

            </Grid>

        </Border>

        <!-- Desna strana -->
        <Border Grid.Row="1"
                Grid.Column="2"
                BorderBrush="Gray"
                BorderThickness="1"
                CornerRadius="5"
                Padding="20">

            <StackPanel Spacing="12">

                <TextBlock Text="Podaci o spravi"
                           FontSize="18"
                           FontWeight="SemiBold"/>

                <TextBlock Text="Naziv sprave:"/>

                <TextBox x:Name="MachineNameTextBox"
                         Watermark="Unesite naziv sprave"/>

                <TextBlock x:Name="StatusTextBlock"
                           Text=""
                           MinHeight="25"
                           TextWrapping="Wrap"/>

                <Button Content="Dodaj novu spravu"
                        Height="42"
                        Click="OnAddMachineClick"/>

                <Button Content="Izmeni izabranu spravu"
                        Height="42"
                        Click="OnUpdateMachineClick"/>

                <Button Content="Obriši izabranu spravu"
                        Height="42"
                        Background="DarkRed"
                        Foreground="White"
                        Click="OnDeleteMachineClick"/>

                <Button Content="Poništi izbor"
                        Height="42"
                        Click="OnClearSelectionClick"/>

            </StackPanel>

        </Border>

        <Button Grid.Row="2"
                Grid.ColumnSpan="3"
                Width="150"
                Height="40"
                Content="Zatvori"
                HorizontalAlignment="Center"
                Margin="0,20,0,0"
                Click="OnCloseClick"/>

    </Grid>

</Window>