<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="OnlineGym.Uix.Views.EquipmentWindow"
        Width="750"
        Height="520"
        MinWidth="650"
        MinHeight="450"
        Title="Upravljanje rekvizitima"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="25"
          RowDefinitions="Auto,*,Auto"
          ColumnDefinitions="2*,20,3*">

        <TextBlock Grid.Row="0"
                   Grid.ColumnSpan="3"
                   Text="Rekviziti za vežbanje"
                   FontSize="26"
                   FontWeight="Bold"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,20"/>

        <Border Grid.Row="1"
                Grid.Column="0"
                BorderBrush="Gray"
                BorderThickness="1"
                CornerRadius="5"
                Padding="10">

            <Grid RowDefinitions="Auto,*">

                <TextBlock Grid.Row="0"
                           Text="Postojeći rekviziti"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Margin="0,0,0,10"/>

                <ListBox x:Name="EquipmentListBox"
                         Grid.Row="1"
                         SelectionChanged="OnEquipmentSelectionChanged"/>

            </Grid>
        </Border>

        <Border Grid.Row="1"
                Grid.Column="2"
                BorderBrush="Gray"
                BorderThickness="1"
                CornerRadius="5"
                Padding="20">

            <StackPanel Spacing="12">

                <TextBlock Text="Podaci o rekvizitu"
                           FontSize="18"
                           FontWeight="SemiBold"/>

                <TextBlock Text="Naziv rekvizita:"/>

                <TextBox x:Name="EquipmentNameTextBox"
                         Watermark="Unesite naziv rekvizita"/>

                <TextBlock x:Name="StatusTextBlock"
                           Text=""
                           MinHeight="25"
                           TextWrapping="Wrap"/>

                <Button Content="Dodaj novi rekvizit"
                        Height="42"
                        Click="OnAddEquipmentClick"/>

                <Button Content="Izmeni izabrani rekvizit"
                        Height="42"
                        Click="OnUpdateEquipmentClick"/>

                <Button Content="Obriši izabrani rekvizit"
                        Height="42"
                        Background="DarkRed"
                        Foreground="White"
                        Click="OnDeleteEquipmentClick"/>

                <Button Content="Poništi izbor"
                        Height="42"
                        Click="OnClearSelectionClick"/>

            </StackPanel>
        </Border>

        <Button Grid.Row="2"
                Grid.ColumnSpan="3"
                Content="Zatvori"
                Width="150"
                Height="40"
                HorizontalAlignment="Center"
                Margin="0,20,0,0"
                Click="OnCloseClick"/>

    </Grid>
</Window>