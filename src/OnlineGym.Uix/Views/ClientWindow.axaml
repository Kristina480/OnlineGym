<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="OnlineGym.Uix.Views.ClientWindow"
        Width="500"
        Height="400"
        Title="Client Dashboard">

    <Grid Margin="20" RowDefinitions="Auto,Auto,Auto,*">
        <Border Grid.Row="1" 
                BorderBrush="Gray" 
                BorderThickness="0,1,0,0" 
                Margin="0,0,0,20"/>

        <StackPanel Grid.Row="2" Spacing="15" HorizontalAlignment="Center">
            <Button Content="Azuriraj svoje podatke"
                    Width="250"
                    Height="50"
                    Click="OnUpdateProfileClick"
                    FontSize="16"/>
          feature/client-workout-rating
			<Button Content="Moji treninzi"
        			Width="250"
        			Height="50"
        			Click="OnWorkoutsClick"
        			FontSize="16"/>

            <Button Content="Oceni vezbe"
                    Width="250"
                    Height="50"
                    Click="OnRateWorkoutItemsClick"
                    FontSize="16"/>
          main
            <Button Content="Odjava"
                    Width="250"
                    Height="50"
                    Click="OnLogoutClick"
                    FontSize="16"
                    Background="DarkRed"
                    Foreground="White"/>
            
            <Button Content="Pregled trenera"
                    Width="250"
                    Height="50"
                    Click="OnBrowseTrainersClick"
                    FontSize="16"/>

            <Button Content="Poruke"
                    Width="250"
                    Height="50"
                    Click="OnMessagesClick"
                    FontSize="16"/>
        </StackPanel>
    </Grid>

</Window>