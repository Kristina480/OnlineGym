<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:dg="using:Avalonia.Controls"
        x:Class="OnlineGym.Uix.Views.CreateWorkoutWindow"
        x:CompileBindings="False"
        Width="1080"
        Height="720"
        MinWidth="900"
        MinHeight="620"
        Title="Kreiranje treninga"
        WindowStartupLocation="CenterScreen">

    <Window.Styles>
        <Style Selector="Button">
            <Setter Property="Padding" Value="16,9"/>
            <Setter Property="CornerRadius" Value="7"/>
        </Style>
        <Style Selector="DataGridColumnHeader">
            <Setter Property="Background" Value="#E9EDF4"/>
            <Setter Property="Foreground" Value="#1F2937"/>
        </Style>
    </Window.Styles>

    <Grid Margin="24" RowDefinitions="Auto,Auto,Auto,*,Auto">
        <StackPanel Grid.Row="0" Spacing="5">
            <TextBlock Text="Kreiranje treninga"
                       FontSize="28"
                       FontWeight="Bold"/>
            <TextBlock Text="Izaberite klijenta i dodajte jednu ili više vežbi u trening."
                       Foreground="#667085"/>
        </StackPanel>

        <Border Grid.Row="1"
                Height="1"
                Background="#D8DEE8"
                Margin="0,16"/>

        <Grid Grid.Row="2"
              ColumnDefinitions="1.5*,1*,1*,1.5*"
              ColumnSpacing="12">
            <StackPanel Grid.Column="0" Spacing="5">
                <TextBlock Text="Klijent"/>
                <ComboBox x:Name="ClientComboBox"
                          SelectionChanged="OnClientSelectionChanged">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Spacing="5">
                                <TextBlock Text="{Binding FirstName}"/>
                                <TextBlock Text="{Binding LastName}"/>
                            </StackPanel>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </StackPanel>

            <StackPanel Grid.Column="1" Spacing="5">
                <TextBlock Text="Datum"/>
                <DatePicker x:Name="WorkoutDatePicker"/>
            </StackPanel>

            <StackPanel Grid.Column="2" Spacing="5">
                <TextBlock Text="Vreme"/>
                <TextBox x:Name="WorkoutTimeTextBox"
                         PlaceholderText="18:00"
                         Text="18:00"/>
            </StackPanel>

            <StackPanel Grid.Column="3" Spacing="5">
                <TextBlock Text="Napomena za trening"/>
                <TextBox x:Name="WorkoutCommentTextBox"/>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="3"
              ColumnDefinitions="1*,1.5*"
              ColumnSpacing="18"
              Margin="0,18,0,0">
            <StackPanel Grid.Column="0" Spacing="12">
                <Border Padding="14"
                        CornerRadius="8"
                        Background="#F4F6F9">
                    <StackPanel Spacing="5">
                        <TextBlock Text="Podaci klijenta"
                                   FontWeight="SemiBold"/>
                        <TextBlock Text="Cilj:" Foreground="#667085"/>
                        <TextBlock x:Name="ClientGoalTextBlock"
                                   Text="Izaberite klijenta"
                                   TextWrapping="Wrap"/>
                        <TextBlock Text="Zdravstveni problemi:"
                                   Foreground="#667085"
                                   Margin="0,5,0,0"/>
                        <TextBlock x:Name="ClientHealthIssuesTextBlock"
                                   Text="Izaberite klijenta"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <Border Padding="14"
                        CornerRadius="8"
                        BorderBrush="#D8DEE8"
                        BorderThickness="1">
                    <StackPanel Spacing="9">
                        <TextBlock Text="Dodavanje stavke treninga"
                                   FontWeight="SemiBold"
                                   FontSize="18"/>
                        <ComboBox x:Name="ExerciseComboBox">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Name}"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        <TextBox x:Name="RepetitionCountTextBox"
                                 PlaceholderText="Broj ponavljanja (opciono)"/>
                        <TextBox x:Name="ItemCommentTextBox"
                                 PlaceholderText="Napomena za vežbu"
                                 AcceptsReturn="True"
                                 Height="70"/>
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                            <Button Grid.Column="0"
                                    Content="Upravljaj vežbama"
                                    Click="OnManageExercisesClick"/>
                            <Button Grid.Column="1"
                                    x:Name="AddWorkoutItemButton"
                                    Content="Dodaj stavku"
                                    Click="OnAddItemClick"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>

            <Border Grid.Column="1"
                    Padding="12"
                    CornerRadius="8"
                    BorderBrush="#D8DEE8"
                    BorderThickness="1">
                <Grid RowDefinitions="Auto,*,Auto">
                    <TextBlock Grid.Row="0"
                               Text="Stavke treninga"
                               FontWeight="SemiBold"
                               FontSize="18"
                               Margin="0,0,0,10"/>

                    <dg:DataGrid Grid.Row="1"
                                 x:Name="WorkoutItemsDataGrid"
                                 AutoGenerateColumns="False"
                                 IsReadOnly="True"
                                 SelectionMode="Single"
                                 GridLinesVisibility="Horizontal"
                                 Background="White">
                        <dg:DataGrid.Columns>
                            <dg:DataGridTextColumn Header="ID vežbe" Binding="{Binding ExerciseId}" Width="*"/>
                            <dg:DataGridTextColumn Header="Ponavljanja" Binding="{Binding RepetitionCount}" Width="*"/>
                            <dg:DataGridTextColumn Header="Napomena" Binding="{Binding Comment}" Width="2*"/>
                        </dg:DataGrid.Columns>
                    </dg:DataGrid>

                    <Button Grid.Row="2"
                            Content="Ukloni izabranu stavku"
                            HorizontalAlignment="Right"
                            Margin="0,10,0,0"
                            Click="OnRemoveItemClick"/>
                </Grid>
            </Border>
        </Grid>

        <Grid Grid.Row="4"
              ColumnDefinitions="Auto,*,Auto"
              Margin="0,18,0,0">
            <Button Grid.Column="0"
                    Content="Nazad"
                    Width="120"
                    Click="OnCloseClick"/>
            <TextBlock Grid.Column="1"
                       x:Name="MessageTextBlock"
                       Margin="18,0"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center"
                       TextWrapping="Wrap"/>
            <Button Grid.Column="2"
                    x:Name="SaveWorkoutButton"
                    Content="Sačuvaj trening"
                    Width="165"
                    Click="OnSaveWorkoutClick"/>
        </Grid>
    </Grid>
</Window>
