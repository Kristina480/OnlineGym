<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="OnlineGym.Uix.Views.MainWindow"
        Width="800"
        Height="450"
        Title="OnlineGym">

    <StackPanel Margin="20"
                Spacing="20"
                VerticalAlignment="Center"
                HorizontalAlignment="Center">

        <TextBlock Text="Welcome"
                   FontSize="28"
                   FontWeight="Bold"
                   HorizontalAlignment="Center" />

        <Button Content="Login"
                Width="140"
                HorizontalAlignment="Center"
                HorizontalContentAlignment="Center"
                VerticalContentAlignment="Center"
                Click="OnLoginClick" />

        <Button Content="Register as client"
                Width="140"
                HorizontalAlignment="Center"
                HorizontalContentAlignment="Center"
                VerticalContentAlignment="Center"
                Click="OnRegisterClientClick" />
        <Button Content="Register as trainer"
                Width="140"
                HorizontalAlignment="Center"
                HorizontalContentAlignment="Center"
                VerticalContentAlignment="Center"
                Click="OnRegisterTrainerClick" />

    </StackPanel>

</Window>