<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="OnlineGym.Uix.Views.UpdateClientWindow"
        Width="450"
        Height="600"
        Title="Azuriraj profil">

    <ScrollViewer>
        <StackPanel Margin="20" Spacing="10">

            <TextBlock Text="Azuriraj svoje podatke"
                       FontSize="24"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"/>

            <TextBox Name="FirstNameBox"
                     Watermark="Ime"/>

            <TextBox Name="LastNameBox"
                     Watermark="Prezime"/>

            <TextBox Name="HeightBox"
                     Watermark="Visina (cm)"/>

            <TextBox Name="WeightBox"
                     Watermark="Tezina (kg)"/>

            <TextBox Name="WorkoutsPerWeekBox"
                     Watermark="Broj treninga nedeljno"/>

            <TextBox Name="GoalBox"
                     Watermark="Cilj (opciono)"/>

            <TextBox Name="HealthIssuesBox"
                     Watermark="Zdravstveni problemi (opciono)"/>

            <Button Content="Sacuvaj izmene"
                    HorizontalAlignment="Center"
                    Click="OnSaveClick"
                    FontSize="16"
                    Margin="0,20,0,0"/>

            <TextBlock Name="ErrorText"
                       Foreground="Red"
                       TextWrapping="Wrap"
                       HorizontalAlignment="Center"/>

        </StackPanel>
    </ScrollViewer>

</Window>